{
  "config": {
    "step": {
      "user": {
        "title": "BMW CarData Setup",
        "description": "Enter your BMW CarData Client ID. You can create one in the BMW portal under 'BMW CarData' section.\n\nPortal: {bmw_portal}",
        "data": {
          "client_id": "Client ID"
        },
        "data_description": {
          "client_id": "Your BMW CarData Client ID from the BMW portal"
        }
      },
      "authorize": {
        "title": "Authorize Device",
        "description": "Please authorize this device by visiting the link below and entering the code.\n\n**Verification URL:** {verification_url}\n\n**Code:** {user_code}\n\n**Note:** This code expires in {expires_minutes} minutes.\n\nClick Submit ONLY after the BMW page confirms successful authorization."
      },
      "reauth_confirm": {
        "title": "Re-authenticate BMW CarData",
        "description": "Your BMW CarData session has expired. Click Submit to start the re-authentication process."
      }
    },
    "error": {
      "auth_error": "Authentication failed. Please check your Client ID and try again.",
      "cannot_connect": "Could not connect to BMW servers. Please try again later.",
      "timeout": "Authorization timed out. Please try again.",
      "unknown": "An unexpected error occurred."
    },
    "abort": {
      "already_configured": "This Client ID is already configured.",
      "reauth_successful": "Re-authentication successful.",
      "unknown_error": "An unknown error occurred during setup."
    }
  },
